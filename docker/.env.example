# Copy this file to .env and adjust the values before running docker compose up.
# Docker Compose loads .env automatically — no extra flags needed.
#
# Variables marked REQUIRED must be set. All others have sensible defaults
# and can be left commented out.

# ── MariaDB credentials ───────────────────────────────────────────────────────
# Shared between the mariadb and qmail services.
# Change these before the first run — they are baked into the database volume.

MYSQL_ROOT_PASS=changeme_root
MYSQL_DB=vpopmail
MYSQL_USER=vpopmail
MYSQL_PASS=changeme

# ── Server identity ───────────────────────────────────────────────────────────
# REQUIRED: fully-qualified domain name of this mail server.
QMAIL_ME=mail.example.com

# Primary virtual domain created in vpopmail on first run.
# Defaults to everything after the first dot in QMAIL_ME if not set.
#QMAIL_DOMAIN=example.com

# ── Queue / concurrency ───────────────────────────────────────────────────────
#QMAIL_SOFTLIMIT=64000000
#QMAIL_CONCURRENCY_INCOMING=200
#QMAIL_CONCURRENCY_REMOTE=20
#QMAIL_CONCURRENCY_LOCAL=10
#QMAIL_DATABYTES=20000000
#QMAIL_MAXRCPT=100
#QMAIL_QUEUELIFETIME=272800

# ── Feature layer toggles ─────────────────────────────────────────────────────
# Each of these 4 features can be handled by "rspamd" (default) or "qmail".
# Setting a value here applies to BOTH containers — the active layer is enabled
# and the other is automatically disabled at startup.
#
# rspamd = rspamd module active, qmail-smtpd feature disabled (default for all 4)
# qmail  = qmail-smtpd feature active, rspamd module disabled
#
#SPF_LAYER=rspamd
#DKIM_VERIFY_LAYER=rspamd
#DNSBL_LAYER=rspamd
#SURBL_LAYER=rspamd

# DNSBL servers to use when DNSBL_LAYER=qmail (space-separated).
# Prefix with - for hard reject (553) vs soft reject (451).
# Has no effect when DNSBL_LAYER=rspamd.
#QMAIL_DNSBL_SERVERS=-zen.spamhaus.org -b.barracudacentral.org -bl.spamcop.net

# ── SMTP behaviour ────────────────────────────────────────────────────────────
# SPF behavior when SPF_LAYER=qmail: 0=off 1=softfail→pass 2=softfail→reject 3=fail→reject
#QMAIL_SPFBEHAVIOR=3

# Greet delay in seconds before the SMTP banner (default: 5, 0=off)
#QMAIL_GREETDELAY=5

# SURBL URI blocklist checking (0=off, 1=on)
#QMAIL_SURBL=0

# Max non-existent recipients before disconnect (brtlimit patch, default: 2)
#QMAIL_BRTLIMIT=2

# Max invalid recipients before disconnect on any port (default: 3)
#QMAIL_CHKUSER_WRONGRCPTLIMIT=3

# Bounce message sender name (default: noreply)
#QMAIL_BOUNCEFROM=noreply

# Seconds a message stays in the queue before bouncing (default: 272800 ≈ 3 days)
#QMAIL_QUEUELIFETIME=272800

# Max messages an authenticated user/domain/IP may send per reset period (default: 1000, 0=unlimited).
# Written to control/relaylimits on first run. Edit that file directly for per-user/domain/IP overrides.
#QMAIL_RELAY_LIMIT=1000

# Dual-stack: bind tcpserver on :: for IPv4+IPv6 (requires Docker IPv6, 0=IPv4 only)
#QMAIL_DUALSTACK=0

# jgreylist binary wrapper on port 25 (0=off, 1=on)
#QMAIL_GREYLISTING=0

# Custom SPF failure explanation message (leave unset for default)
#QMAIL_SPF_EXP=See http://www.open-spf.org/Why

# ── SMTP run-script env vars ──────────────────────────────────────────────────
# These are passed directly into qmail-smtpd's environment.

# Validate HELO hostname against DNS — value is a string of check modes (e.g. PLRIV)
#HELO_DNS_CHECK=PLRIV

# Reject messages with empty envelope sender (<>) — set to any non-empty value to enable
#REJECTNULLSENDERS=1

# Allow DKIM-signed messages where Subject is not in the h= tag (default: 1=allow)
#UNSIGNED_SUBJECT=1

# simscan debug level 0–4 (requires simscan — Step 5 in TODO.md)
#SIMSCAN_DEBUG=0

# ── TLS ──────────────────────────────────────────────────────────────────────
# Provide paths to existing PEM files (e.g. Let's Encrypt).
# Both files must be accessible inside the container (mount via volume).
# Leave unset to generate a self-signed certificate for QMAIL_ME on first run.
#QMAIL_TLS_CERT=/etc/letsencrypt/live/mail.example.com/fullchain.pem
#QMAIL_TLS_KEY=/etc/letsencrypt/live/mail.example.com/privkey.pem

# TLS cipher suite (default follows Mozilla intermediate compatibility)
#QMAIL_TLS_CIPHERS=HIGH:MEDIUM:!MD5:!RC4:!3DES:!LOW:!SSLv2:!SSLv3

# DH params bit size: 2048 (default, fast) or 4096 (slower, stronger)
#QMAIL_DH_BITS=2048

# ── SNI (additional TLS domains) ─────────────────────────────────────────────
# Semicolon-separated triplets: domain:cert_path:key_path
# Re-applied on every container start so renewed certs are picked up automatically.
#QMAIL_SNI_CERTS=mail2.example.org:/etc/letsencrypt/live/mail2.example.org/fullchain.pem:/etc/letsencrypt/live/mail2.example.org/privkey.pem

# ── Relay / access control ────────────────────────────────────────────────────
# Comma-separated IPs or prefixes that may relay on port 25.
# Loopback (127./::1) is always trusted.
#QMAIL_RELAY_NETS=192.168.1.,10.0.0.2

# ── Mail tapping ──────────────────────────────────────────────────────────────
# Semicolon-separated rules for qmail-taps-extended.
# TYPE: F=from  T=to  A=all (catch-all)
#QMAIL_TAPS=F:.*@example.com:archive@example.com

# ── qmail-spp greylisting plugin ─────────────────────────────────────────────
# MySQL-backed greylisting running inside qmail-smtpd via the SPP plugin system.
# Separate from jgreylist (QMAIL_GREYLISTING) — both can run simultaneously.
#
# Set GREYLIST_USER to activate: entrypoint writes control/mysql.cnf,
# control/greylisting (plugin config), and a default control/smtpplugins.
# The MariaDB init script creates the database and schema on first start.
#
# To disable after enabling: remove control/greylisting and control/smtpplugins
# from the volume, then unset GREYLIST_USER.
#GREYLIST_DB=greylisting
#GREYLIST_USER=greylisting
#GREYLIST_PASS=changeme_grey
#GREYLIST_BLOCK_EXPIRE=2         # minutes a new sender is greylisted
#GREYLIST_RECORD_EXPIRE=2000     # minutes until unseen triplet is purged
#GREYLIST_RECORD_EXPIRE_GOOD=36  # hours a good sender stays whitelisted
#GREYLIST_LOGLEVEL=4

# ── vqadmin HTTP auth ─────────────────────────────────────────────────────────
# vqadmin is the system-level domain management interface, protected by HTTP basic auth.
# VQADMIN_PASS is auto-generated and printed to stdout on first run if left unset.
#VQADMIN_USER=admin
#VQADMIN_PASS=changeme
