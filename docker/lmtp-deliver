#!/bin/bash
# LMTP delivery script for qmail → Dovecot
# Called from .qmail-default with: |/var/qmail/bin/lmtp-deliver
#
# Exit codes: 0=success, 111=temp fail (retry), 100=perm fail (bounce)

LMTP_HOST="${LMTP_HOST:-dovecot}"
LMTP_PORT="${LMTP_PORT:-24}"

[ -z "$EXT" ] || [ -z "$HOST" ] && { echo "lmtp-deliver: EXT/HOST not set" >&2; exit 100; }

RECIPIENT="${EXT}@${HOST}"

# Read message to temp file
MSG=$(mktemp)
trap 'rm -f "$MSG"' EXIT
cat > "$MSG"
[ -s "$MSG" ] || { echo "lmtp-deliver: empty message" >&2; exit 100; }

# Open TCP connection using bash /dev/tcp.
# Do NOT redirect stderr here — exec with 2>/dev/null would permanently
# silence all subsequent error output for this script.
exec 3<>/dev/tcp/"$LMTP_HOST"/"$LMTP_PORT" || {
    echo "lmtp-deliver: cannot connect to $LMTP_HOST:$LMTP_PORT" >&2
    exit 111
}

# Helper: read LMTP/SMTP response lines until the final line for the given
# 3-digit code.  Final lines match "NNN <text>"; continuation lines match
# "NNN-<text>" and are consumed silently.
read_resp() {
    local line
    while IFS= read -r line <&3; do
        line="${line%$'\r'}"  # Strip CR
        case "$line" in
            "$1 "*|"$1")  return 0 ;;          # Final line: "250 OK"
            "$1-"*)       ;;                   # Continuation: "250-PIPELINING"
            4??)          echo "lmtp-deliver: temp fail: $line" >&2; exit 111 ;;
            4??\ *|4??-*) echo "lmtp-deliver: temp fail: $line" >&2; exit 111 ;;
            5??)          echo "lmtp-deliver: perm fail: $line" >&2; exit 100 ;;
            5??\ *|5??-*) echo "lmtp-deliver: perm fail: $line" >&2; exit 100 ;;
            *)            echo "lmtp-deliver: unexpected: $line" >&2; exit 111 ;;
        esac
    done
    echo "lmtp-deliver: connection closed unexpectedly" >&2
    exit 111
}

# LMTP conversation
read_resp 220                           # Greeting
echo "LHLO qmail" >&3
read_resp 250                           # LHLO response (may be multi-line)
echo "MAIL FROM:<${SENDER}>" >&3
read_resp 250
echo "RCPT TO:<${RECIPIENT}>" >&3
read_resp 250
echo "DATA" >&3
read_resp 354

# Send message body — dot-stuff lines that start with a literal dot
sed 's/^\./\.\./' "$MSG" >&3
echo "." >&3
read_resp 250                           # Delivery confirmation

echo "QUIT" >&3
exec 3>&-

exit 0
